{
  "compilerOptions": {
    "target":             "ES2022",
    "lib":                ["ES2022"],
    "module":             "ESNext",
    "moduleResolution":   "bundler",
    "esModuleInterop":    true,
    "resolveJsonModule":  true,
    "isolatedModules":    true,
    "noEmit":             true,
    "strict":             true,
    "skipLibCheck":       true,

    /* Acesso a tipos do Node.js no vite.config.ts */
    "types": ["node"]
  },

  "include": [
    "vite.config.ts",
    "tailwind.config.js",
    "postcss.config.js"
  ]
}