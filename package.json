{
  "name": "danfe-gen",
  "private": true,
  "version": "1.0.0",
  "description": "DanfeGen — Conversor de XML NF-e para DANFE PDF e Etiqueta Térmica 80mm",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Alberto Luiz",
    "email": "alberto.dos.santos93@gmail.com",
    "url": "https://github.com/alberto2santos"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alberto2santos/danfe-gen"
  },
  "keywords": [
    "danfe",
    "nfe",
    "xml",
    "pdf",
    "nota-fiscal",
    "sefaz",
    "fiscal",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Edge versions",
      "last 2 Firefox versions"
    ],
    "development": [
      "last 1 Chrome version"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
